# =============================================================================
# Epsilon Platform - Environment Configuration
# Copy this file: cp .env.example .env
# =============================================================================
#
# Production instance: <PRODUCTION_URL>
#

# --- OpenAI API Key (optional) ---
# Used by the AI Agent worker for automated code analysis (CrewAI).
# Not required — jobs will skip AI analysis if unset.
OPENAI_API_KEY=

# --- Service Ports ---
# Override defaults if you have port conflicts.
API_PORT=3334
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000
JOB_SCHEDULER_PORT=3005
TRUST_CENTER_PORT=3001

# --- Coordinator Settings ---
POLLING_INTERVAL=5
LOG_LEVEL=INFO
SESSION_SECRET=dev-session-secret-change-me

# --- GitHub OAuth (optional) ---
# Enables connecting Git repos to workspaces in the Job Scheduler.
# Create at: https://github.com/settings/developers → New OAuth App
# Callback URL: http://localhost:3005/api/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

