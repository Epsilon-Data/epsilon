  "clients": [
    {
      "clientId": "${TOKEN_HANDLER_CLIENT_ID}",
      "name": "OAUTH Token Handler Client",
      "description": "Handles OAUTH tokens (BFF)",
      "clientAuthenticatorType": "client-secret",
      "secret": "${TOKEN_HANDLER_CLIENT_SECRET}",
      "redirectUris": ["${TOKEN_HANDLER_REDIRECT_URIS}"],
      "webOrigins": ["${TOKEN_HANDLER_WEB_ORIGIN}"],
      "notBefore": 0,
      "bearerOnly": false,
      "consentRequired": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": true,
      "publicClient": false,
      "frontchannelLogout": false,
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "user_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {
            "lightweight.claim": "false",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ],
      "defaultClientScopes": [
        "openid",
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email",
        "epsilon.api"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "authorizationSettings": {
        "allowRemoteResourceManagement": true,
        "policyEnforcementMode": "ENFORCING",
        "scopes": [
          {
            "name": "view",
            "iconUri": "",
            "displayName": "View resource"
          },
          {
            "name": "edit",
            "iconUri": "",
            "displayName": "Edit resource"
          },
          {
            "name": "delete",
            "iconUri": "",
            "displayName": "Delete resource"
          },
          {
            "name": "connect",
            "iconUri": "",
            "displayName": "Connect datasource"
          },
          {
            "name": "approve",
            "iconUri": "",
            "displayName": "Approve access to resource"
          },
          {
            "name": "analysis",
            "iconUri": "",
            "displayName": "Run analysis"
          },
          {
            "name": "stats",
            "iconUri": "",
            "displayName": "Run stats"
          }
        ],
        "decisionStrategy": "AFFIRMATIVE"
      }
    }
  ]
}
