{
  "enumDefs": [
    {
      "name": "analysis_access_level",
      "description": "Access control levels for archetype nodes analysis",
      "serviceType": "archetype",
      "typeVersion": "1.0",
      "elementDefs": [
        {
          "value": "NONE",
          "description": "No analytical access",
          "ordinal": 0
        },
        {
          "value": "HIGH_LEVEL",
          "description": "Access limited to high-level or aggregated data",
          "ordinal": 1
        },
        {
          "value": "DETAILED",
          "description": "Access to full detailed or record-level data",
          "ordinal": 2
        }
      ],
      "defaultValue": "NONE"
    },
    {
      "name": "template_status",
      "description": "Status of an archetype or template object",
      "typeVersion": "1.0",
      "serviceType": "archetype",
      "elementDefs": [
        {
          "value": "DRAFT",
          "description": "Template is in draft mode and not yet published",
          "ordinal": 0
        },
        {
          "value": "PUBLISHED",
          "description": "Template is finalized and published for use",
          "ordinal": 1
        }
      ],
      "defaultValue": "DRAFT"
    },
    {
      "name": "node_type",
      "description": "Type of an archetype_node",
      "typeVersion": "1.0",
      "serviceType": "archetype",
      "elementDefs": [
        {
          "value": "ROOT",
          "description": "Archetype root node",
          "ordinal": 0
        },
        {
          "value": "BRANCH",
          "description": "Archetype branch node",
          "ordinal": 1
        },
        {
          "value": "LEAF",
          "description": "Archetype leaf node",
          "ordinal": 2
        }
      ]
    }
  ],
